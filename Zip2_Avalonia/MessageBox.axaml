<Window
    x:Class="Zip2_Avalonia.MessageBox"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Сообщение"
    Width="400"
    Height="200"
    CanResize="False"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Name="MessageText"
            Grid.Row="0"
            VerticalAlignment="Center"
            TextWrapping="Wrap" />

        <Button
            Grid.Row="1"
            Width="100"
            Height="30"
            HorizontalAlignment="Center"
            Click="OkButton_Click">
            OK
        </Button>
    </Grid>
</Window>