<Window
    x:Class="Zip2_Avalonia.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="BMP Lab Work 2"
    Width="1200"
    Height="700"
    Background="{DynamicResource ThemeBackgroundBrush}"
    WindowStartupLocation="CenterScreen">

    <Design.PreviewWith>
        <Border Padding="20">
            <ContentPresenter />
        </Border>
    </Design.PreviewWith>

    <Grid Margin="20" RowDefinitions="Auto, *, Auto">
        <!--  Header Panel  -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,20"
            Padding="16"
            Background="{DynamicResource ThemeAccentBrush4}"
            BorderBrush="{DynamicResource ThemeBorderMidBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="12">
                <TextBlock
                    FontSize="20"
                    FontWeight="Medium"
                    Text="Лабораторная работа №2: Анализ BMP файлов"
                    TextWrapping="Wrap" />

                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <Button
                        Name="btnSelectImage"
                        Height="40"
                        MinWidth="160"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Classes="PrimaryButton"
                        Content="Выбрать BMP файл" />

                    <Border
                        Padding="8,4"
                        Background="{DynamicResource ThemeControlHighBrush}"
                        CornerRadius="4">
                        <TextBlock
                            Name="txtStatus"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Opacity="0.8"
                            Text="Готов к работе" />
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!--  Main Content Area  -->
        <Grid
            Grid.Row="1"
            ColumnDefinitions="*, 350"
            ColumnSpacing="20"
            RowSpacing="0">

            <!--  Left Panel: Image Preview  -->
            <Border
                Grid.Column="0"
                Padding="16"
                Background="{DynamicResource ThemeBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <DockPanel>
                    <TextBlock
                        Margin="0,0,0,12"
                        DockPanel.Dock="Top"
                        FontSize="16"
                        FontWeight="Medium"
                        Text="Предварительный просмотр" />

                    <Grid Margin="0,8,0,0" RowDefinitions="*, Auto">
                        <Border
                            Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{DynamicResource ThemeControlLowBrush}"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Image
                                Name="imgPreview"
                                MaxWidth="800"
                                MaxHeight="400"
                                Margin="16"
                                Stretch="Uniform" />
                        </Border>

                        <TextBlock
                            Name="txtImageInfo"
                            Grid.Row="1"
                            Margin="0,12,0,0"
                            FontSize="12"
                            Opacity="0.7"
                            TextAlignment="Center" />
                    </Grid>
                </DockPanel>
            </Border>

            <!--  Right Panel: BMP Header Info  -->
            <Border
                Grid.Column="1"
                Padding="16"
                Background="{DynamicResource ThemeBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <DockPanel>
                    <TextBlock
                        Margin="0,0,0,12"
                        DockPanel.Dock="Top"
                        FontSize="16"
                        FontWeight="Medium"
                        Text="Информация о файле" />

                    <ScrollViewer
                        Padding="4"
                        DockPanel.Dock="Bottom"
                        VerticalScrollBarVisibility="Auto">
                        <TextBlock
                            Name="txtHeaderInfo"
                            FontFamily="Cascadia Code, Consolas, monospace"
                            FontSize="11"
                            LineHeight="16"
                            Opacity="0.9"
                            TextWrapping="Wrap" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!--  Bottom Panel: Controls  -->
        <Border
            Grid.Row="2"
            Margin="0,20,0,0"
            Padding="16"
            Background="{DynamicResource ThemeAccentBrush4}"
            BorderBrush="{DynamicResource ThemeBorderMidBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="16">
                <TextBlock
                    FontSize="14"
                    FontWeight="Medium"
                    Text="Режимы обработки" />

                <StackPanel Orientation="Horizontal" Spacing="24">
                    <ToggleButton
                        Name="rbGrayscale"
                        Classes="RadioButtonStyle"
                        Content="Чёрно-белый"
                        IsChecked="True" />

                    <ToggleButton
                        Name="rbColored"
                        Classes="RadioButtonStyle"
                        Content="Цветной" />

                    <ToggleButton
                        Name="rbBoth"
                        Classes="RadioButtonStyle"
                        Content="Оба режима" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        Name="btnProcess"
                        Height="44"
                        MinWidth="200"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Classes="SuccessButton"
                        Content="Выполнить анализ"
                        IsEnabled="False" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>