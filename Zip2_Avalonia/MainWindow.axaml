<Window
    x:Class="Zip2_Avalonia.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="BMP Lab Work 2"
    Width="1200"
    Height="700"
    Background="#1E1E1E"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20" RowDefinitions="Auto, *, Auto">

        <!-- HEADER -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,20"
            Padding="16"
            Background="#2A2A2A"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="10">

            <StackPanel Spacing="12">

                <TextBlock
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="Анализ BMP файлов" />

                <Separator />

                <StackPanel Orientation="Horizontal" Spacing="12">

                    <Button
                        Name="btnSelectImage"
                        Click="BtnSelectImage_Click"
                        Height="40"
                        MinWidth="180"
                        Background="#3A3A3A"
                        Foreground="White"
                        CornerRadius="6"
                        Content="Выбрать BMP файл" />
                    
                    <Button
                        Name="btnSelectRle"
                        Click="BtnSelectRle_Click"
                        Height="40"
                        MinWidth="180"
                        Background="#555"
                        Foreground="White"
                        CornerRadius="6"
                        Content="Выбрать RLE файл"/>

                    <Border
                        Padding="8,4"
                        Background="#333"
                        CornerRadius="6">

                        <StackPanel Orientation="Vertical">

                            <TextBlock
                                Name="txtStatus"
                                Foreground="#A8E6CF"
                                FontSize="12"
                                Text="Готов к работе"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </StackPanel>
        </Border>

        <!-- MAIN -->
        <Grid
            Grid.Row="1"
            ColumnDefinitions="2*, 3*"
            ColumnSpacing="20">

            <!-- IMAGE -->
            <Border
                Grid.Column="0"
                Padding="16"
                Background="#2A2A2A"
                BorderBrush="#444"
                BorderThickness="1"
                CornerRadius="10">

                <DockPanel>

                    <TextBlock
                        DockPanel.Dock="Top"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Предпросмотр" />

                    <Separator Margin="0,10" />

                    <Grid RowDefinitions="*, Auto">

                        <Border
                            Background="#1A1A1A"
                            BorderBrush="#444"
                            BorderThickness="1"
                            CornerRadius="6">

                            <Image
                                Name="imgPreview"
                                MaxWidth="800"
                                MaxHeight="400"
                                Margin="16"
                                Stretch="Uniform" />
                        </Border>

                        <TextBlock
                            Name="txtImageInfo"
                            Grid.Row="1"
                            Margin="0,12,0,0"
                            Foreground="#CCC"
                            FontSize="12"
                            TextAlignment="Center" />
                    </Grid>

                </DockPanel>
            </Border>

            <!-- INFO -->
            <Border
                Grid.Column="1"
                Padding="16"
                Background="#2A2A2A"
                BorderBrush="#444"
                BorderThickness="1"
                CornerRadius="10">

                <DockPanel>

                    <TextBlock
                        DockPanel.Dock="Top"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Информация" />

                    <Separator Margin="0,10" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <TextBlock
                            Name="txtHeaderInfo"
                            FontFamily="Cascadia Code, Consolas"
                            FontSize="20"
                            Foreground="#DDD"
                            TextWrapping="Wrap" />
                    </ScrollViewer>

                </DockPanel>
            </Border>

        </Grid>

        <!-- BOTTOM -->
        <Border
            Grid.Row="2"
            Margin="0,20,0,0"
            Padding="16"
            Background="#2A2A2A"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="10">

            <StackPanel Spacing="12">

                <TextBlock
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="Режим обработки" />

                <Separator />

                <StackPanel Orientation="Horizontal" Spacing="20">

                    <RadioButton
                        Name="rbGrayscale"
                        IsChecked="True"
                        GroupName="Mode"
                        Background="#3A3A3A"
                        Foreground="White"
                        Content="Ч/Б" />

                    <RadioButton
                        Name="rbColored"
                        GroupName="Mode"
                        Background="#3A3A3A"
                        Foreground="White"
                        Content="Цветной" />

                    <RadioButton
                        Name="rbBoth"
                        GroupName="Mode"
                        Background="#3A3A3A"
                        Foreground="White"
                        Content="Оба" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">

                    <Button
                        Name="btnEmbedSecret"
                        Click="BtnEmbedSecret_Click"
                        Height="44"
                        MinWidth="180"
                        Background="#9C27B0"
                        Foreground="White"
                        CornerRadius="6"
                        Content="Встроить секрет"
                        IsEnabled="False" />

                    <Button
                        Name="btnExtractSecret"
                        Click="BtnExtractSecret_Click"
                        Height="44"
                        MinWidth="180"
                        Background="#E91E63"
                        Foreground="White"
                        CornerRadius="6"
                        Content="Извлечь секрет"
                        IsEnabled="False" />

                    <Button
                        Name="btnEncode"
                        Click="BtnEncode_Click"
                        Height="44"
                        MinWidth="180"
                        Background="#2196F3"
                        Foreground="White"
                        CornerRadius="6"
                        Content="RLE Кодировать"
                        IsEnabled="False" />

                    <Button
                        Name="btnDecode"
                        Click="BtnDecode_Click"
                        Height="44"
                        MinWidth="180"
                        Background="#FF9800"
                        Foreground="White"
                        CornerRadius="6"
                        Content="RLE Декодировать"
                        IsEnabled="False" />

                    <Button
                        Name="btnProcess"
                        Click="BtnProcess_Click"
                        Height="44"
                        MinWidth="220"
                        Background="#4CAF50"
                        Foreground="White"
                        CornerRadius="6"
                        Content="Запустить анализ"
                        IsEnabled="False" />
                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</Window>